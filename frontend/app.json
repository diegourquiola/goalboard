{
  "expo": {
    "name": "GoalBoard",
    "slug": "goalboard",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/logo.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#0D1117"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.goalboard.app",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/logo.png",
        "backgroundColor": "#0D1117"
      },
      "package": "com.goalboard.app"
    },
    "web": {
      "favicon": "./assets/logo.png"
    },
    "extra": {
      "eas": {
        "projectId": "110f1985-4112-4926-a0b6-e0ff3d4fa0b2"
      }
    },
    "plugins": [
      "expo-web-browser",
      [
        "expo-notifications",
        {
          "icon": "./assets/logo.png",
          "color": "#007AFF"
        }
      ],
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Allow GoalBoard to use Face ID to unlock the app."
        }
      ]
    ]
  }
}
